MONGO_DB_URI=mongodb://127.0.0.1:27017/yet-another-mtg-database

# For bulk data import
ALL_CARDS_FILE=bulk-data/oracle-cards-20251025210907.json

# Scryfall API base URL (used to fetch individual cards and set icons on demand)
SCRYFALL_API_BASE_URL=https://api.scryfall.com

# Set to "true" to disable login and run as a single shared local user
# (no Google OAuth). The fixed user + an active "Main Collection" are created
# automatically. Leave unset (or "false") for normal authenticated mode.
DISABLE_LOGIN=false

# For Google OAuth (not required when DISABLE_LOGIN=true)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
AUTH_SECRET=your_random_secret_key

# Card scanner backend (proxied by POST /api/scan)
SCANNER_BASE_URL=http://localhost:8000

# For Next Auth
NEXTAUTH_URL=https://yourdomain.com